APP_NAME="DAYA AI"

# Nama mesin yang tampil di panel admin (bisa disesuaikan tiap instalasi/klien).
DAYA_ENGINE_NAME="DAYA AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (RFP: MariaDB / MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cegu
DB_USERNAME=cegu
DB_PASSWORD=

# --- Akun admin awal (dipakai oleh seeder AdminUserSeeder) ---
ADMIN_EMAIL=admin@cegu.test
ADMIN_PASSWORD=ubah-password-ini

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: database cukup untuk MVP. Upgrade ke redis bila perlu throughput tinggi.
QUEUE_CONNECTION=database

# Cache: file/redis di produksi. Jangan pakai 'array' (cache tidak persist).
CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Patch performa (2026-07-11) ---
# Cache HTML halaman publik (detik). 0 = nonaktif. Produksi: gunakan Redis.
DAYA_PAGE_CACHE_TTL=900
# Cache daftar halaman kategori/hub (detik).
DAYA_CATEGORY_CACHE_TTL=600

# --- AI: pool konten, keyword, & Asisten SEO ---
# driver: openrouter | anthropic | openai | deepseek | groq | custom
#
# REKOMENDASI: openrouter — satu kunci untuk semua model, ganti model cukup
# ubah AI_MODEL (format: vendor/model). Salin slug persis dari halaman model
# OpenRouter, jangan mengetik dari ingatan.
AI_DRIVER=openrouter
AI_API_KEY=
AI_MODEL=anthropic/claude-sonnet-5
#
# Alternatif (API langsung):
#   AI_DRIVER=anthropic  + AI_MODEL=claude-sonnet-5 | claude-opus-4-8 | claude-haiku-4-5-20251001
#   AI_DRIVER=deepseek   + AI_MODEL=deepseek-chat        (paling murah)
#   AI_DRIVER=openai     + AI_MODEL=gpt-4o-mini
# Kosongkan untuk pakai preset driver. Isi hanya untuk endpoint lain (Together/Mistral/LLM lokal).
AI_BASE_URL=
AI_TIMEOUT=120

# --- IndexNow: indexing kilat (Bing/Yandex/Naver/Seznam) ---
# Isi string hex acak (mis. 32 karakter). Kosong = nonaktif.
# Halaman yang dipublish otomatis dikirim ke IndexNow. Verifikasi via /indexnow.txt.
INDEXNOW_KEY=

# --- Keamanan: izinkan Blade (eksekusi PHP) di template salespage ---
# Default false. Nyalakan (true) HANYA bila operator template 100% tepercaya,
# DAN aktifkan juga toggle-nya di panel Pengaturan.
DAYA_TEMPLATE_BLADE=false

# --- Anti halaman tipis (keunikan) ---
DAYA_THIN_MIN_FACTS=2
DAYA_THIN_CANONICAL_HUB=true

# --- Rate limit halaman publik (per menit per IP) ---
DAYA_PUBLIC_RATE_LIMIT=120

# --- Google Search Console API (opsional, monitoring) ---
# Path ke file JSON service account, ATAU JSON mentah. Aktifkan "Search Console API"
# di Google Cloud, lalu tambahkan email service account sebagai user di properti GSC.
GSC_CREDENTIALS=
# Properti GSC: 'sc-domain:contoh.com' atau 'https://contoh.com/'. Kosong = domain app.
GSC_SITE_URL=
