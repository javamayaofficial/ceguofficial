# =============================================================================
# CEGU pSEO — Contoh .env PRODUKSI (skala jutaan halaman)
# Salin nilai relevan ke .env server. JANGAN commit .env asli ke Git.
# =============================================================================

APP_NAME="CEGU"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://contoh.com

# Wajib: generate sekali → php artisan key:generate
APP_KEY=

# --- Database (halaman/konten) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cegu
DB_USERNAME=cegu
DB_PASSWORD=ganti_ini

# --- Cache & Queue via Redis (DIREKOMENDASIKAN di skala besar) ---
# Butuh ekstensi phpredis (disarankan) atau paket predis/predis.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0             # queue
REDIS_CACHE_DB=1       # cache (boleh LRU-evict)

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Nama cookie session (dipakai aturan bypass micro-cache di Nginx).
SESSION_COOKIE=cegu_session

# --- TTL cache render halaman (detik). 900 = 15 menit. ---
CEGU_PAGE_CACHE_TTL=900
CEGU_CATEGORY_CACHE_TTL=600

# --- Rate limit publik (per IP/menit) ---
CEGU_PUBLIC_RATE_LIMIT=120

# --- Anti halaman tipis ---
CEGU_THIN_MIN_FACTS=2
CEGU_THIN_CANONICAL_HUB=true

# --- AI (isi pool konten & keyword) ---
AI_DRIVER=deepseek
AI_API_KEY=
AI_MODEL=deepseek-chat

# --- IndexNow (indexing kilat) ---
INDEXNOW_KEY=

# --- Google Search Console (monitoring, opsional) ---
GSC_CREDENTIALS=
GSC_SITE_URL=https://contoh.com/

# --- Keamanan: Blade di template hanya untuk operator tepercaya ---
CEGU_TEMPLATE_BLADE=false

# =============================================================================
# Setelah deploy, jalankan:
#   composer install --no-dev --optimize-autoloader
#   php artisan key:generate           # bila APP_KEY kosong
#   php artisan migrate --force
#   php artisan config:cache route:cache view:cache
#   php artisan storage:link
# Worker antrian dijalankan lewat Supervisor (lihat deploy/supervisor).
# =============================================================================
